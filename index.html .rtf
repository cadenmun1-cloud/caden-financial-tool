    \}\
  </style>\
</head>\
\
<body>\
\
<h1>Caden Munro \'96 Financial Analysis Tool</h1>\
\
<div class="container">\
\
  <p><strong>Stock Ticker (AAPL, TSLA, MSFT)</strong></p>\
  <input id="ticker" placeholder="Enter stock ticker">\
\
  <p><strong>Risk-Free Rate (%)</strong></p>\
  <input id="rf" placeholder="e.g. 2">\
\
  <button onclick="calculate()">Calculate</button>\
\
  <div class="results">\
    <p><strong>Average Return:</strong> <span id="avg"></span></p>\
    <p><strong>Volatility:</strong> <span id="vol"></span></p>\
    <p><strong>Beta:</strong> <span id="beta"></span></p>\
    <p><strong>Sharpe Ratio:</strong> <span id="sharpe"></span></p>\
  </div>\
\
</div>\
\
<script>\
\
async function getData(ticker) \{\
  let url = `https://query1.finance.yahoo.com/v8/finance/chart/$\{ticker\}?range=1mo&interval=1d`;\
  let res = await fetch(url);\
  let data = await res.json();\
  return data.chart.result[0].indicators.quote[0].close;\
\}\
\
function returns(prices) \{\
  let r = [];\
  for (let i = 1; i < prices.length; i++) \{\
    r.push(((prices[i] - prices[i-1]) / prices[i-1]) * 100);\
  \}\
  return r;\
\}\
\
function avg(arr) \{\
  return arr.reduce((a,b)=>a+b,0)/arr.length;\
\}\
\
function std(arr, mean) \{\
  let v = arr.reduce((s,x)=> s + Math.pow(x-mean,2),0)/arr.length;\
  return Math.sqrt(v);\
\}\
\
function beta(stock, market) \{\
  let avgS = avg(stock);\
  let avgM = avg(market);\
\
  let cov = 0, varM = 0;\
\
  for (let i = 0; i < stock.length; i++) \{\
    cov += (stock[i]-avgS)*(market[i]-avgM);\
    varM += Math.pow(market[i]-avgM,2);\
  \}\
\
  return cov / varM;\
\}\
\
async function calculate() \{\
  let ticker = document.getElementById("ticker").value;\
  let rf = Number(document.getElementById("rf").value);\
\
  let stockPrices = await getData(ticker);\
  let marketPrices = await getData("SPY");\
\
  let stockR = returns(stockPrices);\
  let marketR = returns(marketPrices);\
\
  let average = avg(stockR);\
  let volatility = std(stockR, average);\
  let b = beta(stockR, marketR);\
  let sharpe = (average - rf) / volatility;\
\
  document.getElementById("avg").innerText = average.toFixed(2) + "%";\
  document.getElementById("vol").innerText = volatility.toFixed(2);\
  document.getElementById("beta").innerText = b.toFixed(2);\
  document.getElementById("sharpe").innerText = sharpe.toFixed(2);\
\}\
\
</script>\
\
