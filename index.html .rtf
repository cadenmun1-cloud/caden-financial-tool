\f0\fs24 \cf0 <!DOCTYPE html>\
<html>\
<head>\
  <title>Caden Munro Financial Analysis Tool</title>\
\
  <style>\
    body \{\
      font-family: Arial;\
      background-color: #f5f7fa;\
      padding: 30px;\
      text-align: center;\
    \}\
\
    .container \{\
      background: white;\
